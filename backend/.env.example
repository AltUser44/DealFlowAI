PORT=4000
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/dealflow
ALPHA_VANTAGE_API_KEY=your_key
ANTHROPIC_API_KEY=your_key
# Required for JWT auth — set a long random secret in production
JWT_SECRET=change-me-in-production
# Optional: override Claude model (default: claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-haiku-4-5
# Comma-separated tickers for npm run sync
DEFAULT_SYMBOLS=MSFT,AAPL,GOOGL,AMZN,JPM
